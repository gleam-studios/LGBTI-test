# =============================================================================
# 环境变量 — 用法二选一
#   A) 本地：复制本文件为 .env.local ，按需改值后保存
#   B) Vercel：Project → Settings → Environment Variables，逐条「名称 + 值」添加
# 说明：以 # 开头的行是注释；复制到 Vercel 时不要带注释行，只填键值对。
# =============================================================================

# --- 必填（生产环境请改成你的真实域名，含 https，不要末尾 /）---
NEXT_PUBLIC_SITE_URL=https://lgbti-test.com

# --- 可选：文案版别。留空 = 默认；若需大陆温和版，填 cn-safe ---
NEXT_PUBLIC_VARIANT=

# --- 可选：PostHog 分析。KEY 留空 = 不采集 ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- 可选：Sentry 错误监控（未接入构建插件时可能无效果，可先留空）---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Google AdSense：发布商 ID（全站加载脚本 + Google「验证站点」会检查此项）---
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-7248894390538261

# --- Google AdSense：结果页底部自适应广告位的 slot ID（纯数字，AdSense 后台「广告单元」里复制）---
# 若留空：验证站点仍可只靠 CLIENT；但结果页不会出现正式广告位 ---
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=

# --- 上线后请在域名根目录放置 ads.txt（Google AdSense 后台会给出文件内容）---
# 例如：public/ads.txt 或单独路由，URL 必须是 https://你的域名/ads.txt
