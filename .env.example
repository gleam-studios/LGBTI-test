# Canonical site URL used for OG images and absolute links.
NEXT_PUBLIC_SITE_URL=https://rainbow-elevator.app

# Content variant switch. Leave empty for the default (uncensored) copy.
# Set to `cn-safe` to use the softer mainland-China variant.
# NEXT_PUBLIC_VARIANT=cn-safe

# Vercel Analytics works automatically on Vercel deployments.

# PostHog (optional). Without these keys, no events are captured.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (optional). If present, Next will use the plugin at build time.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# Google AdSense — 结果页底部广告位（两者都填才显示；公开变量仅含 pub id 与广告位 id）
# 申请与审核见：https://www.google.com/adsense
# 上线后还应在域名根目录提供 ads.txt，见项目说明或 AdSense 后台指引
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_RESULT=1234567890
